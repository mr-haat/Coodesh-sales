{
  "info": {
    "name": "Sales API",
    "description": "Requests for the Sales API. Set the baseUrl variable to the running API URL and the saleId/itemId variables from the responses.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5080"
    },
    {
      "key": "saleId",
      "value": ""
    },
    {
      "key": "itemId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create Sale",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/sales",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "sales"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"saleNumber\": \"SALE-0001\",\n  \"saleDate\": \"2026-07-03T00:00:00Z\",\n  \"customerId\": \"11111111-1111-1111-1111-111111111111\",\n  \"customerName\": \"John Doe\",\n  \"branchId\": \"22222222-2222-2222-2222-222222222222\",\n  \"branchName\": \"Downtown Branch\",\n  \"items\": [\n    {\n      \"productId\": \"aaaaaaaa-0000-0000-0000-000000000001\",\n      \"productName\": \"Widget A\",\n      \"quantity\": 5,\n      \"unitPrice\": 100.0\n    },\n    {\n      \"productId\": \"aaaaaaaa-0000-0000-0000-000000000002\",\n      \"productName\": \"Widget B\",\n      \"quantity\": 10,\n      \"unitPrice\": 50.0\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "List Sales",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/sales?_page=1&_size=10&_order=saleDate desc",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "sales"
          ],
          "query": [
            {
              "key": "_page",
              "value": "1"
            },
            {
              "key": "_size",
              "value": "10"
            },
            {
              "key": "_order",
              "value": "saleDate desc"
            }
          ]
        }
      }
    },
    {
      "name": "Get Sale",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/sales/{{saleId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "sales",
            "{{saleId}}"
          ]
        }
      }
    },
    {
      "name": "Update Sale",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/sales/{{saleId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "sales",
            "{{saleId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"saleNumber\": \"SALE-0001\",\n  \"saleDate\": \"2026-07-03T00:00:00Z\",\n  \"customerId\": \"11111111-1111-1111-1111-111111111111\",\n  \"customerName\": \"John Doe (updated)\",\n  \"branchId\": \"22222222-2222-2222-2222-222222222222\",\n  \"branchName\": \"Downtown Branch\",\n  \"items\": [\n    {\n      \"productId\": \"aaaaaaaa-0000-0000-0000-000000000001\",\n      \"productName\": \"Widget A\",\n      \"quantity\": 4,\n      \"unitPrice\": 100.0\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Cancel Sale Item",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/sales/{{saleId}}/items/{{itemId}}/cancel",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "sales",
            "{{saleId}}",
            "items",
            "{{itemId}}",
            "cancel"
          ]
        }
      }
    },
    {
      "name": "Cancel Sale",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/sales/{{saleId}}/cancel",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "sales",
            "{{saleId}}",
            "cancel"
          ]
        }
      }
    },
    {
      "name": "Delete Sale",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/sales/{{saleId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "sales",
            "{{saleId}}"
          ]
        }
      }
    }
  ]
}